{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "incremental": true,
    "paths": {
      "@atempo/shared": ["packages/shared/dist"],
      "@atempo/shared/*": ["packages/shared/dist/*"]
    }
  },
  "include": ["src", "test"]
}
